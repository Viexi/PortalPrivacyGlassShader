{
    "m_SGVersion": 1,
    "m_Type": "UnityEditor.ShaderGraph.CustomFunctionNode",
    "m_ObjectId": "ebf290642aa74f0da6465a2da325a328",
    "m_Group": {
        "m_Id": "463f86c4498f44e7baa895237f2e821c"
    },
    "m_Name": "GaussianBlur (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": 3159.999755859375,
            "y": 1408.0,
            "width": 228.0,
            "height": 117.9998779296875
        }
    },
    "m_Slots": [
        {
            "m_Id": "7de0c66c6e8d40fab40907d490c23199"
        },
        {
            "m_Id": "22e2331e23414db8982cab967a4f6c90"
        },
        {
            "m_Id": "9a1294eb93464a0681b715eb9b732f55"
        },
        {
            "m_Id": "c1e405eec29c47478320783b68fde458"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": false,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "GaussianBlur",
    "m_FunctionSource": "",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "#ifndef SHADERGRAPH_PREVIEW\n#include \"Packages/com.unity.render-pipelines.universal/ShaderLibrary/DeclareOpaqueTexture.hlsl\"\n#include \"Packages/com.unity.render-pipelines.universal/ShaderLibrary/DeclareDepthTexture.hlsl\"\n\nfloat weight[5] = {0.0545, 0.2442, 0.4026, 0.2442, 0.0545};\nfloat3 sum = float3(0.0, 0.0, 0.0);\n\n[unroll]\nfor(int i = -2; i <= 2; i++) {\n    [unroll]\n    for(int j = -2; j <= 2; j++) {\n        float2 sampleUV = UV + float2(i, j) * BlurRadius;\n        float w = weight[i+2] * weight[j+2];\n        \n        float rawDepth = SampleSceneDepth(sampleUV);\n        float linearDepth = LinearEyeDepth(rawDepth, _ZBufferParams);\n        \n        if(linearDepth >= FragmentDepth) {\n            sum += SAMPLE_TEXTURE2D_X_LOD(_CameraOpaqueTexture, sampler_CameraOpaqueTexture, sampleUV, 0).rgb * w;\n        } else {\n            sum += SAMPLE_TEXTURE2D_X_LOD(_CameraOpaqueTexture, sampler_CameraOpaqueTexture, UV, 0).rgb * w;\n        }\n    }\n}\nOut = sum;\n\n#else\nOut = float3(0.0, 0.0, 0.0);\n#endif"
}

