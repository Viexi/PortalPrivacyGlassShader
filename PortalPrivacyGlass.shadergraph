{
    "m_SGVersion": 1,
    "m_Type": "UnityEditor.ShaderGraph.CustomFunctionNode",
    "m_ObjectId": "7459ffee8908481e896e5eb8c4612a93",
    "m_Group": {
        "m_Id": "31f8da1d0e884d078240060b0c3b8cbb"
    },
    "m_Name": "PortalStyleBlur (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": 3109.999755859375,
            "y": 1189.9998779296875,
            "width": 239.0,
            "height": 118.0
        }
    },
    "m_Slots": [
        {
            "m_Id": "f130dcc02ed547e79ba7be2a2442f830"
        },
        {
            "m_Id": "a6c8ef5c8ae8428c908129ba59edc915"
        },
        {
            "m_Id": "f9f8da0ddc0a405799adabb7b386825f"
        },
        {
            "m_Id": "9388525a5bb340a2b6cf9a431cd6edfb"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": false,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "PortalStyleBlur",
    "m_FunctionSource": "",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "#ifndef SHADERGRAPH_PREVIEW\n#include \"Packages/com.unity.render-pipelines.universal/ShaderLibrary/DeclareOpaqueTexture.hlsl\"\n#include \"Packages/com.unity.render-pipelines.universal/ShaderLibrary/DeclareDepthTexture.hlsl\"\n\nfloat3 sum = float3(0.0, 0.0, 0.0);\n\nfloat2 offsets[3] = {\n    float2(-1.0, 0.0),\n    float2(0.0, 0.0),\n    float2(1.0, 0.0)\n};\n\nfloat weights[3] = {0.25, 0.5, 0.25};\n\n[unroll]\nfor(int i = 0; i < 3; i++) {\n    float2 sampleUV = UV + offsets[i] * BlurRadius;\n    \n    float rawDepth = SampleSceneDepth(sampleUV);\n    float linearDepth = LinearEyeDepth(rawDepth, _ZBufferParams);\n    \n    if(linearDepth >= FragmentDepth) {\n        sum += SAMPLE_TEXTURE2D_X_LOD(_CameraOpaqueTexture, sampler_CameraOpaqueTexture, sampleUV, 0).rgb * weights[i];\n    } else {\n        sum += SAMPLE_TEXTURE2D_X_LOD(_CameraOpaqueTexture, sampler_CameraOpaqueTexture, UV, 0).rgb * weights[i];\n    }\n}\n\nOut = sum;\n\n#else\nOut = float3(0.0, 0.0, 0.0);\n#endif"
}

